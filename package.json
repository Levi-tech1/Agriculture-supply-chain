{
  "name": "agricultural-supply-chain",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Blockchain-based Agricultural Supply Chain Management System",
  "workspaces": [
    "contracts",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build -w frontend",
    "dev": "kill-port 4000 5173 && concurrently \"npm run dev:backend\" \"npm run dev:frontend:fixed\"",
    "dev:full": "kill-port 4000 5173 && concurrently \"npm run dev:backend\" \"npm run dev:frontend:fixed\"",
    "contracts:compile": "npm run compile -w contracts",
    "contracts:test": "npm run test -w contracts",
    "contracts:node": "npm run node -w contracts",
    "backend:dev": "npm run dev -w backend",
    "frontend:dev": "npm run dev -w frontend",
    "frontend:dev:fixed": "npm run dev -w frontend -- --port 5173 --strictPort",
    "dev:chain": "npm run node -w contracts",
    "dev:backend": "kill-port 4000 && npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:frontend:fixed": "npm run dev -w frontend -- --port 5173 --strictPort"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  }
}
