PORT=4000
# Leave empty or set to "memory" to use in-memory DB (no MongoDB install needed). Or set to mongodb://localhost:27017/agri-supply-chain
# On Vercel: MONGODB_URI is REQUIRED (e.g. MongoDB Atlas). Add in Vercel Project → Settings → Environment Variables.
# MONGODB_URI=
CONTRACT_ADDRESS=
ETH_RPC_URL=http://127.0.0.1:8545
JWT_SECRET=change-this-secret-in-production
FRONTEND_URL=http://localhost:5173
# CORS: use your deployed frontend origin. Multiple URLs (production + Vercel preview): comma-separated, no spaces.
# Example: https://myapp.vercel.app,https://myapp-git-main-user.vercel.app
# When backend is on Render/Railway and frontend on Vercel, set FRONTEND_URL to the Vercel site URL(s).

# Optional: force which Mongo user the API uses when not using login (24-char hex id).
# DEFAULT_USER_ID=

# Optional: auto-create one login for local dev (not used on Vercel unless you set ALLOW_USER_SEED=1 in production)
# After adding these, restart the backend once. Then sign in with this email + password.
# SEED_USER_EMAIL=you@gmail.com
# SEED_USER_PASSWORD=at-least-6-chars
# SEED_USER_NAME=Your Name
# SEED_USER_ROLE=farmer

# Owner (admin) – set to create first owner account; owner can then log in
# OWNER_EMAIL=owner@example.com
# OWNER_PASSWORD=your-secure-password
# OWNER_NAME=Owner
# OWNER_WALLET=0x0000000000000000000000000000000000000001

# Stripe subscriptions (optional). Create Products + recurring Prices in Stripe Dashboard, then:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from `stripe listen` or Dashboard webhook
# STRIPE_PRICE_GROWTH=price_...      # monthly price for Growth plan
# STRIPE_PRICE_ENTERPRISE=price_... # monthly price for Enterprise plan
# Webhook URL: POST {BACKEND_URL}/api/webhooks/stripe — events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
