VITE_CONTRACT_ADDRESS=

# Production API (pick one approach):
#
# A) Same-origin /api (default): In Vercel → Settings → Environment Variables set BACKEND_URL (no VITE_ prefix)
#    to your Express server origin ONLY, e.g. https://your-api.onrender.com
#    Do NOT include /api at the end (avoids /api/api/...). Redeploy after saving.
#    Your API host must have MONGODB_URI set (e.g. Atlas); the app creates a demo user if the DB is empty.
#    Use Vercel project Root Directory = repository root, OR Root Directory = frontend (proxy lives in frontend/api/).
#
# B) Direct API URL: set before build: VITE_API_URL=https://your-api.onrender.com (no trailing slash).
#    Backend must allow CORS for your Vercel domain.
# VITE_API_URL=https://your-api.onrender.com

# Base URL for QR codes (MUST be HTTPS for iPhone scan). Use ngrok or your domain for phone demo.
# Example: https://abcd1234.ngrok.io or https://yourdomain.com
# Leave empty to use current page origin (same machine only).
# VITE_VERIFY_BASE_URL=https://yourdomain.com

# Dev-only auto login (never enable in production). After `npm run dev`, opens /login and signs in automatically.
# VITE_AUTO_LOGIN=true
# VITE_AUTO_LOGIN_EMAIL=you@example.com
# VITE_AUTO_LOGIN_PASSWORD=your-password
# Optional delay before request (ms). Default 500.
# VITE_AUTO_LOGIN_DELAY_MS=500
